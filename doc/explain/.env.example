

# --- Elasticsearch ---------------------------------------------------------
ES_URL=http://localhost:
ES_USERNAME=elastic
ES_PASSWORD=change-me-in-secret-manager
INDEX_NAME=poc_policy_index

# --- Embedding -------------------------------------------------------------
ROUTER_SERVICE_ENDPOINT=http://
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSION=1536

# --- Hybrid search tuning --------------------------------------------------
BM25_BOOST=0.5
KNN_BOOST=0.5
KNN_NUM_CANDIDATES=100

# --- Service ---------------------------------------------------------------
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30
